# pyenv
#   For a library or package, you might want to ignore these files since the Python version is up to the user.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you prefer keeping your dependencies personal:
# Pipfile.lock

# poetry
#   Using Poetry requires Pipfile and poetry.lock to be tracked in Git.
#   If you want to isolate your dependencies:
# poetry.lock

# pdm
#   PDM stores project-wide configurations in .pdm.toml
.pdm.toml
.pdm-plugins/

